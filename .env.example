# Health Connect — Environment Variables

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
DB_PATH=./data/health.db
LOG_FORMAT=text
CORS_ORIGINS=http://localhost:3000

# ─── Oura ────────────────────────────────────────────────────────────────────
OURA_ACCESS_TOKEN=

# ─── Strava ──────────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ─── Hevy ────────────────────────────────────────────────────────────────────
HEVY_AUTH_TOKEN=
HEVY_API_KEY=

# ─── InBody ──────────────────────────────────────────────────────────────────
INBODY_LOGIN_ID=
INBODY_PASSWORD=

# ─── AI Analysis ─────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Sync Schedules (cron expressions) ───────────────────────────────────────
OURA_SYNC_CRON=0 */6 * * *
HEVY_SYNC_CRON=0 */4 * * *
STRAVA_SYNC_CRON=0 */6 * * *
INBODY_SYNC_CRON=0 8 * * 0
